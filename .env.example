# Optional: enable real FileMaker Data API mode. If unset, app runs in local mock mode.
FILEMAKER_HOST=https://fms007.abdenterprises.com
FILEMAKER_DATABASE=Assets
FILEMAKER_USERNAME=Admin
FILEMAKER_PASSWORD=Admin123

# Phase 9 enterprise profile controls
WEBIDE_ENV_PROFILE=DEV
WEBIDE_AUTH_MODE=disabled

# Trusted-header mode example:
# WEBIDE_AUTH_MODE=trusted-header
# WEBIDE_SSO_HEADER=x-forwarded-user

# JWT/OIDC mode examples:
# WEBIDE_AUTH_MODE=oidc
# WEBIDE_JWT_ISSUER=https://login.example.com/tenant/v2.0
# WEBIDE_JWT_AUDIENCE=fm-web-ide
# WEBIDE_OIDC_JWKS_JSON={"keys":[...]}

# Security controls
WEBIDE_CSRF_ENABLED=false
WEBIDE_AUDIT_ENABLED=true
WEBIDE_AUDIT_RETENTION_DAYS=30
WEBIDE_RATE_LIMIT_ENABLED=true
WEBIDE_RATE_LIMIT_WINDOW_MS=60000
WEBIDE_RATE_LIMIT_MAX_REQUESTS=400
WEBIDE_CIRCUIT_BREAKER_ENABLED=true
WEBIDE_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
WEBIDE_CIRCUIT_BREAKER_COOLDOWN_MS=15000
