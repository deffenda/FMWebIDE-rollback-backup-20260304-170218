{
  "name": "fm-web-ide",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "fmweb-plugin": "./scripts/fmweb-plugin.mjs"
  },
  "scripts": {
    "clean": "rm -rf .next",
    "dev": "next dev --turbopack",
    "dev:reset": "npm run clean && next dev --turbopack",
    "import:ddr": "node scripts/import-ddr-layouts.mjs",
    "import:themes": "node scripts/import-filemaker-themes.mjs",
    "import:theme-palettes": "node scripts/build-filemaker-theme-palettes.mjs",
    "audit:ddr-inspector": "node scripts/audit-ddr-inspector-mapping.mjs",
    "audit": "node --no-warnings=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/audit/run-audit.ts",
    "audit:ci": "node --no-warnings=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/audit/run-audit.ts --ci",
    "build": "next build",
    "build:reset": "npm run clean && next build",
    "build:prod": "WEBIDE_ENV_PROFILE=PROD NODE_ENV=production next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs,.mts",
    "typecheck": "tsc --noEmit",
    "quality": "npm run typecheck && npm run lint && npm test && npm run build",
    "test": "npm run test:fmcalc && npm run test:edit-session && npm run test:runtime-parity && npm run test:phase1-foundation && npm run test:layout-geometry && npm run test:fm-styles && npm run test:find-mode && npm run test:sort-reporting && npm run test:summary-engine && npm run test:field-engine && npm run test:portal && npm run test:runtime-controls && npm run test:tabs && npm run test:tab-order && npm run test:list-table-runtime && npm run test:saved-searches && npm run test:view-configs && npm run test:feature-flags && npm run test:app-layer && npm run test:triggers && npm run test:trigger-policy && npm run test:value-lists && npm run test:privileges && npm run test:runtime-kernel && npm run test:script-advanced && npm run test:transactions && npm run test:browse-url && npm run test:menu-actions && npm run test:webdirect-runtime && npm run test:layout-fidelity-engines && npm run test:layout-import && npm run test:workspace-multifile && npm run test:dev-tools && npm run test:security && npm run test:plugin-sdk && npm run test:perf-primitives && npm run test:versioning && npm run test:governance && npm run test:admin-console",
    "test:fmcalc": "node --experimental-strip-types --test src/lib/fmcalc/fmcalc.test.mts",
    "test:edit-session": "node --experimental-strip-types --test src/lib/edit-session/edit-session.test.mts",
    "test:runtime-parity": "node --experimental-strip-types --test src/lib/runtime-parity.test.mts",
    "test:phase1-foundation": "node --experimental-strip-types --test src/lib/parity-matrix-report.test.mts src/server/parity-diagnostics.test.mts",
    "test:layout-geometry": "node --experimental-strip-types --test src/fm/layout/geometry/__tests__/anchors.test.ts src/fm/layout/geometry/__tests__/parts.test.ts src/fm/layout/geometry/__tests__/render-tree.test.ts",
    "test:fm-styles": "node --experimental-strip-types --test src/fm/styles/__tests__/resolveStyle.test.ts src/fm/styles/__tests__/cssFromTokens.test.ts",
    "test:find-mode": "node --experimental-strip-types --test src/lib/find-mode.test.mts",
    "test:sort-reporting": "node --experimental-strip-types --test src/lib/sort-reporting.test.mts src/lib/sort-dialog-ops.test.mts",
    "test:summary-engine": "node --experimental-strip-types --test src/lib/summary-engine.test.mts",
    "test:field-engine": "node --experimental-strip-types --test src/lib/field-engine.test.mts",
    "test:portal": "node --experimental-strip-types --test src/lib/portal-utils.test.mts src/lib/portal-runtime.test.mts",
    "test:runtime-controls": "node --experimental-strip-types --test src/lib/runtime-field-controls.test.mts",
    "test:tabs": "node --experimental-strip-types --test src/lib/tabs-runtime.test.mts",
    "test:tab-order": "node --experimental-strip-types --test src/lib/tab-order.test.mts",
    "test:list-table-runtime": "node --experimental-strip-types --test src/lib/list-table-runtime.test.mts",
    "test:saved-searches": "node --experimental-strip-types --test src/server/saved-search-storage.test.mts",
    "test:view-configs": "node --experimental-strip-types --test src/server/view-config-storage.test.mts",
    "test:feature-flags": "node --experimental-strip-types --test src/config/featureFlags.test.mts",
    "test:app-layer": "node --experimental-strip-types --test src/config/appLayerCapabilities.test.mts src/lib/app-layer-menu.test.mts src/lib/manage-security-ops.test.mts src/server/app-layer-storage.test.mts src/server/manage-value-lists.test.mts",
    "test:triggers": "node --experimental-strip-types --test src/lib/triggers/triggers.test.mts",
    "test:trigger-policy": "node --experimental-strip-types --test src/lib/trigger-policy.test.mts",
    "test:value-lists": "node --experimental-strip-types --test src/lib/value-list-cache.test.mts",
    "test:privileges": "node --experimental-strip-types --test src/lib/runtime-capabilities.test.mts",
    "test:runtime-kernel": "node --experimental-strip-types --test src/lib/runtime-kernel/foundset-store.test.mts src/lib/runtime-kernel/window-manager.test.mts src/lib/runtime-kernel/variable-store.test.mts src/lib/runtime-kernel/context-stack.test.mts src/lib/runtime-kernel/script-workspace-mapper.test.mts src/lib/runtime-kernel/script-engine.test.mts src/lib/runtime-kernel/kernel.test.mts",
    "test:script-advanced": "node --experimental-strip-types --test src/lib/runtime-kernel/script-engine-advanced.test.mts",
    "test:transactions": "node --experimental-strip-types --test src/lib/runtime-kernel/transaction-manager.test.mts",
    "test:browse-url": "node --experimental-strip-types --test src/lib/browse-url-state.test.mts",
    "test:menu-actions": "node --experimental-strip-types --test src/lib/menu-action-coverage.test.mts src/menu/filemaker-menu-spec.test.mts src/menu/menu-enablement.test.mts",
    "test:layout-fidelity-engines": "node --experimental-strip-types --test src/lib/layout-fidelity/anchor-engine.test.mts src/lib/layout-fidelity/style-resolver.test.mts src/lib/layout-fidelity/interaction-router.test.mts",
    "test:layout-import": "node --experimental-strip-types --test src/lib/layout-import-regression.test.mts src/lib/layout-fidelity-import.test.mts",
    "test:workspace-multifile": "node --experimental-strip-types --test src/server/workspace-multifile.test.mts src/server/filemaker-client-multifile.test.mts",
    "test:dev-tools": "node --experimental-strip-types --test src/lib/dev-tools.test.mts",
    "test:security": "node --experimental-strip-types --test src/server/enterprise-config.test.mts src/server/security/security-hardening.test.mts src/server/audit-log.test.mts src/server/resilience/circuit-breaker.test.mts",
    "test:plugin-sdk": "node --experimental-strip-types --test src/plugins/plugin-sdk.test.mts",
    "test:perf-primitives": "node --experimental-strip-types --test src/lib/performance/virtual-window.test.mts src/server/performance/request-cache.test.mts",
    "test:versioning": "node --experimental-strip-types --test src/server/workspace-versioning.test.mts",
    "test:governance": "node --experimental-strip-types --test src/lib/governance-rbac.test.mts src/server/workspace-governance-storage.test.mts",
    "test:admin-console": "node --experimental-strip-types --test src/server/admin-console.test.mts",
    "test:webdirect-runtime": "node --experimental-strip-types --test src/server/runtime/object-ids.test.mts src/server/runtime/render-tree-objects.test.mts src/server/runtime/session-store.test.mts",
    "test:parity": "node --experimental-strip-types --test tests/parity/*.test.mts",
    "test:fm-regression": "FM_INTEGRATION_TESTS=1 node --experimental-strip-types --experimental-specifier-resolution=node --test src/server/filemaker-regression.test.mts",
    "test:ui-regression": "npm run test:menu-actions && npm run test:app-layer && npm run test:portal && npm run test:runtime-controls && npm run test:runtime-parity && npm run test:layout-fidelity-engines",
    "test:ui": "node --experimental-strip-types scripts/run-ui-tests.mts",
    "test:ui:headed": "node --experimental-strip-types scripts/run-ui-tests.mts --headed",
    "test:ui:trace": "node --experimental-strip-types scripts/run-ui-tests.mts --trace",
    "parity:ui": "node --experimental-strip-types scripts/parity/run-ui-parity.ts",
    "parity:ui:update-baseline": "node --experimental-strip-types scripts/parity/run-ui-parity.ts --update-baseline",
    "parity:ui:report": "node --experimental-strip-types scripts/parity/run-ui-parity.ts --report-only",
    "bench:perf": "node --experimental-strip-types scripts/bench-perf.mts",
    "test:layout-fidelity": "node --experimental-strip-types scripts/layout-fidelity.mts",
    "test:layout-fidelity:update-baselines": "node --experimental-strip-types scripts/layout-fidelity-update-baselines.mts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "next": "^16.1.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^22.13.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9.20.1",
    "eslint-config-next": "^16.1.6",
    "typescript": "^5.7.3"
  }
}
